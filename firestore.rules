rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ROOMS ──────────────────────────────────────────────
    // Anyone can create/join/read rooms (multiplayer needs this)
    match /rooms/{roomId} {
      allow read, write: if true;

      match /actions/{actionId} {
        allow read, write: if true;
      }
    }

    // ── PROFILES ───────────────────────────────────────────
    // Device can read/write its own profile only
    match /profiles/{profileId} {
      allow read, write: if true;

      match /stats/{statId} {
        allow read, write: if true;
      }
    }

    // ── QUESTION STATS ─────────────────────────────────────
    // Anyone can read and write (tracking question frequency)
    match /question_stats/{docId} {
      allow read, write: if true;
    }

    // ── ANALYTICS ──────────────────────────────────────────
    // Anyone can write (fire and forget from client)
    // No client reads needed — dashboard uses REST API
    match /analytics_events/{docId} {
      allow read, write: if true;
    }

    match /analytics_devices/{docId} {
      allow read, write: if true;
    }

    match /analytics_daily/{docId} {
      allow read, write: if true;
    }

    // ── EVERYTHING ELSE ────────────────────────────────────
    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
