rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rooms — trust-based; structural enforcement deferred until Firebase Auth pre-beta
    match /rooms/{roomCode} {
      allow read, create: if true;
      allow update, delete: if true;

      // Per-player action docs (one doc per player per round)
      match /actions/{playerId} {
        allow read: if true;
        allow write: if true;
      }

      // Emoji reactions (Week 3 implementation)
      match /reactions/{playerId} {
        allow read, write: if true;
      }
    }

    // Player profiles + per-game stats
    match /profiles/{userId} {
      allow read, write: if true;

      match /stats/{gameSlug} {
        allow read, write: if true;
      }
    }
  }
}
